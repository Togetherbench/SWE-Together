# Thin child Dockerfile — uses comfyui-dev base image
# Generated by scripts/rewrite_task_dockerfiles.py
FROM ghcr.io/togetherbench/togetherbench/comfyui-dev:latest
ARG REBUILD_TOKEN=v043-20260430  # cache-bust to force rebuild on top of new base layers

ARG BASE_COMMIT=5ac3b26a7dedb9b13c681abe8733c54f13353273

RUN cd /workspace/ComfyUI && \
    git fetch --depth=1 origin ${BASE_COMMIT} && \
    git checkout -f FETCH_HEAD

# [v043-fix] test.sh's torch-import probe runs before `source /workspace/venv/bin/activate`,
# so `python3` resolves to system /usr/bin/python3 (no torch) — FATAL-zeros the verifier.
# Cannot symlink /usr/bin/python3 → venv python (the venv's own python3 already points
# back at /usr/bin/python3 — circular). Fix by mirroring the comfyui-dev pip set into
# system python so torch + transitive deps are importable from /usr/bin/python3 too.
# Cost: ~500MB extra image size; minimal viable fix without restructuring base venv.
RUN /usr/bin/python3 -m pip install --break-system-packages --no-cache-dir \
        --extra-index-url https://download.pytorch.org/whl/cpu \
        torch==2.6.0+cpu torchvision==0.21.0+cpu transformers==4.47.1 \
        safetensors==0.5.2 aiohttp==3.11.11 einops==0.8.0 pyyaml==6.0.2 \
        Pillow==11.1.0 scipy==1.15.1 tqdm==4.67.1 psutil==6.1.1 \
        tokenizers==0.21.0 sentencepiece==0.2.0 spandrel==0.4.1 \
        pytest==8.3.4 pytest-timeout==2.3.1 opencv-python-headless==4.10.0.84 \
        numpy==1.26.4 \
    && /usr/bin/python3 -m pip uninstall -y --break-system-packages \
        nvidia-cublas-cu12 nvidia-cuda-cupti-cu12 nvidia-cuda-nvrtc-cu12 \
        nvidia-cuda-runtime-cu12 nvidia-cudnn-cu12 nvidia-cufft-cu12 \
        nvidia-curand-cu12 nvidia-cusolver-cu12 nvidia-cusparse-cu12 \
        nvidia-nccl-cu12 nvidia-nvjitlink-cu12 nvidia-nvtx-cu12 triton 2>/dev/null || true \
    && /usr/bin/python3 -c "import torch; print('system torch', torch.__version__)"

WORKDIR /workspace/ComfyUI

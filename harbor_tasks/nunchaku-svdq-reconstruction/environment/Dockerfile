FROM ubuntu:24.04@sha256:c4a8d5503dfb2a3eb8ab5f807da5bc69a85730fb49b5cfca2330194ebcc41c7b
ARG REBUILD_TOKEN=v042-20260430  # cache-bust to force rebuild on top of new base layers

ENV DEBIAN_FRONTEND=noninteractive
ENV LANG=C.UTF-8

RUN apt-get update && apt-get install -y --no-install-recommends \
    git curl ca-certificates python3 python3-pip python3-venv \
    build-essential tmux asciinema \
    && rm -rf /var/lib/apt/lists/*

RUN mkdir -p /workspace /logs/verifier

# Clone nunchaku at pinned commit
RUN git init /workspace/nunchaku && \
    cd /workspace/nunchaku && \
    git remote add origin https://github.com/mit-han-lab/nunchaku.git && \
    git fetch --depth=1 origin 8f41840596bd516d434a1f88ac16c86fdb64e74f && \
    git checkout FETCH_HEAD

# Install CPU-only PyTorch + minimal deps (no CUDA required)
# pyyaml is required by the verifier's auto_gate_bridge to load
# test_manifest.yaml — without it, F2P gates aren't registered in
# /logs/verifier/gates.json and canonical reward drops to 0.
RUN pip install --no-cache-dir --break-system-packages \
    torch==2.6.0+cpu --index-url https://download.pytorch.org/whl/cpu && \
    pip install --no-cache-dir --break-system-packages safetensors==0.7.0 pyyaml==6.0.2

# Set PYTHONPATH so nunchaku package is importable
ENV PYTHONPATH=/workspace/nunchaku

WORKDIR /workspace

# Create keys reference files (tensor shape documentation)
RUN printf 'attn.to_out.0.proj_down  [3072, 128]  BF16\nattn.to_out.0.proj_up    [3072, 128]  BF16\nattn.to_out.0.qweight    [3072, 1536] I8\nattn.to_out.0.smooth_factor [3072]   BF16\nattn.to_out.0.wscales    [48, 3072]  BF16\nimg_mlp.net.2.proj_down  [12288, 128] BF16\nimg_mlp.net.2.proj_up    [3072, 128]  BF16\nimg_mlp.net.2.qweight    [3072, 6144] I8\nimg_mlp.net.2.smooth_factor [12288]  BF16\nimg_mlp.net.2.wscales    [192, 3072] BF16\n' > /workspace/keys_svdq_r128.txt

# Synthesize test data and buggy initial reconstruct_weight.py
RUN echo '' | base64 -d > /tmp/synthesize_buggy_state.py
RUN python3 /tmp/synthesize_buggy_state.py && rm /tmp/synthesize_buggy_state.py

# Remove any files that could interfere with agents
RUN rm -f /workspace/AGENTS.md /workspace/CLAUDE.md

# Make the initial qweight unpack genuinely buggy (the generated code
# accidentally has the correct inverse permute -- swap two indices to break it)
RUN sed -i 's/permute(0, 3, 6, 4, 8, 1, 2, 7, 5, 9)/permute(0, 3, 4, 6, 8, 1, 2, 7, 5, 9)/' /workspace/reconstruct_weight.py

# Configure git for agent commits
RUN git config --global user.email "agent@test.com" && \
    git config --global user.name "Test Agent" && \
    cd /workspace && git init && git add -A && \
    git commit -m "initial workspace state"

# Pre-install Claude Code CLI v2.1.108 (pinned for reproducibility — harness
# version is part of the image hash). Harbor's install-claude-code.sh detects
# `claude` in PATH and skips runtime install when this is present.
RUN curl -fsSL https://claude.ai/install.sh | bash -s -- 2.1.108
ENV PATH="/root/.local/bin:$PATH"

# === BEGIN corpus-wide git-seal (PR #212) ===
# Prevent agent contamination via `git checkout main` / `git log origin/main` /
# `git cherry-pick <sha>`. Recipe: union of SWE-bench PR #471 +
# SWE-bench Pro strip_future_history.py. See bayes.net/swebench-hack/ for
# the exploit pattern; PR #212 for verification on pi-mono.
RUN cd /workspace/nunchaku && \
    git remote remove origin 2>/dev/null || true && \
    git for-each-ref --format='delete %(refname)' refs/heads refs/remotes refs/tags | git update-ref --stdin && \
    rm -f .git/FETCH_HEAD .git/ORIG_HEAD .git/packed-refs && \
    git reflog expire --expire=now --all && \
    git gc --prune=now --aggressive && \
    BASE_TS=$(git show -s --format=%ci HEAD) && \
    AFTER_TS=$(date -d "$BASE_TS + 1 second" '+%Y-%m-%d %H:%M:%S') && \
    [ "$(git log --oneline --all --since="$AFTER_TS" | wc -l)" -eq 0 ] || { echo "LEAK: future commits reachable" >&2; exit 1; }
# === END corpus-wide git-seal ===

# === BEGIN DNS sinkhole (PR #221) ===
COPY seal-dns.sh /usr/local/bin/seal-dns.sh
RUN chmod +x /usr/local/bin/seal-dns.sh && \
    if id agent >/dev/null 2>&1; then \
        (command -v sudo >/dev/null 2>&1 || (apt-get update -qq && apt-get install -y -qq --no-install-recommends sudo > /dev/null)) && \
        (grep -q "^agent ALL=" /etc/sudoers 2>/dev/null || echo "agent ALL=(ALL) NOPASSWD:ALL" >> /etc/sudoers); \
    fi
ENV BASH_ENV=/usr/local/bin/seal-dns.sh
ENV ENV=/usr/local/bin/seal-dns.sh
# === END DNS sinkhole ===
WORKDIR /workspace

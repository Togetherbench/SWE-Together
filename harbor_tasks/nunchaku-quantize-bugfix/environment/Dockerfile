FROM ubuntu:24.04@sha256:c4a8d5503dfb2a3eb8ab5f807da5bc69a85730fb49b5cfca2330194ebcc41c7b
ARG REBUILD_TOKEN=v042-20260430  # cache-bust to force rebuild on top of new base layers

ENV DEBIAN_FRONTEND=noninteractive
ENV LANG=C.UTF-8
ENV LC_ALL=C.UTF-8

# System dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    git \
    curl \
    ca-certificates \
    python3 \
    python3-pip \
    python3-venv \
    build-essential \
    tmux \
    && rm -rf /var/lib/apt/lists/*

# Create workspace and log dirs
RUN mkdir -p /workspace /logs/verifier

WORKDIR /workspace

# Clone nunchaku at commit f86ad47 (feat: pythonized model and QwenImage Support).
# This commit has all relevant dequantization kernel files the agent needs to read:
# - src/kernels/zgemm/gemm_w4a4.cuh + gemm_base.cuh (SVDQ W4A4 kernel)
# - src/kernels/awq/dequantize.cuh (AWQ dequantization)
# - nunchaku/lora/flux/packer.py (NunchakuWeightPacker reference implementation)
# Note: nunchaku itself is NOT installed (requires CUDA compilation) — agent reads source only.
RUN git init /workspace/nunchaku && \
    cd /workspace/nunchaku && \
    git remote add origin https://github.com/mit-han-lab/nunchaku.git && \
    git fetch --depth=1 origin f86ad47001de7b7f48e0ff592a19ac5d3a2d7f09 && \
    git checkout FETCH_HEAD

# Set up Python virtual environment
RUN python3 -m venv /workspace/venv
ENV PATH="/workspace/venv/bin:$PATH"
ENV VIRTUAL_ENV="/workspace/venv"

# Install CPU-only PyTorch + dependencies needed by quantize.py
RUN pip install --no-cache-dir \
    torch==2.6.0+cpu \
    --index-url https://download.pytorch.org/whl/cpu

RUN pip install --no-cache-dir \
    safetensors==0.5.3 \
    tqdm==4.67.1 \
    packaging==24.2

# Write the buggy quantize.py that the agent must fix.
# Bugs present:
#   1. quantize_residual: .max(dim=-1, keepdim=True) returns namedtuple, needs .values
#   2. quantize_awq_layer: .min/.max(dim=-1, keepdim=True) same bug — returns namedtuple
#   3. main(): f"{name}.{weight}" and f"{name}.{bias}" use tensor variables in f-string
#      instead of string literals "weight" / "bias"
RUN echo '' | base64 -d > /workspace/quantize.py

# Write keys_bf16.txt — BF16 model parameter names/shapes (single transformer block shown)
RUN echo '' | base64 -d > /workspace/keys_bf16.txt

# Write keys_svdq_r128.txt — SVDQ quantized model parameter names/shapes
RUN echo '' | base64 -d > /workspace/keys_svdq_r128.txt

# Configure git for agent use
RUN git config --global user.email "agent@test.com" && \
    git config --global user.name "Test Agent"

# Create non-root user for Claude Code (--dangerously-skip-permissions requires non-root)
RUN useradd -m -s /bin/bash agent && \
    chown -R agent:agent /workspace /logs

# Pre-install Claude Code CLI as agent user
# Harbor install.sh target dir (fix for mkdir-as-nonroot bug)
RUN mkdir -p /installed-agent && chown agent:agent /installed-agent
USER agent
# Pre-install Claude Code CLI v2.1.108 (pinned for reproducibility — harness
# version is part of the image hash). Harbor's install-claude-code.sh detects
# `claude` in PATH and skips runtime install when this is present.
RUN curl -fsSL https://claude.ai/install.sh | bash -s -- 2.1.108
ENV PATH="/home/agent/.local/bin:/workspace/venv/bin:$PATH"

# Switch back to root for final setup
USER root

# Remove any AGENTS.md or CLAUDE.md that might block agents
RUN rm -f /workspace/AGENTS.md /workspace/CLAUDE.md /workspace/nunchaku/AGENTS.md /workspace/nunchaku/CLAUDE.md

# Git config for agent user too
RUN su - agent -c 'git config --global user.email "agent@test.com" && git config --global user.name "Test Agent"'

# Initialize git in /workspace so oracle_replay discovers /workspace as the
# repo dir (the canonical patch targets /workspace/quantize.py, which lives
# OUTSIDE the cloned /workspace/nunchaku git repo). Without this, repo
# discovery falls back to /workspace/nunchaku and `git apply` resolves
# quantize.py relative to that wrong dir.
RUN cd /workspace && git init -q && git add -A 2>/dev/null && git -c user.email=t@e -c user.name=t commit -q -m "baseline" || true

WORKDIR /workspace

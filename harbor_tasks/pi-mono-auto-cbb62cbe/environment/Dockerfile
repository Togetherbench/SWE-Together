FROM ghcr.io/togetherbench/togetherbench/pi-mono-dev:latest

ARG BASE_COMMIT=cb08758696daa313da58d24cce14e6dcaf752d61

RUN cd /workspace/pi-mono && \
    git fetch --depth=1 origin ${BASE_COMMIT} && \
    git checkout FETCH_HEAD && \
    npm ci --ignore-scripts 2>/dev/null || true

WORKDIR /workspace/pi-mono

# Thin child Dockerfile — uses comfyui-dev base image
# Generated by scripts/rewrite_task_dockerfiles.py
FROM ghcr.io/togetherbench/togetherbench/comfyui-dev:latest
ARG REBUILD_TOKEN=v042-20260430  # cache-bust to force rebuild on top of new base layers

ARG BASE_COMMIT=1ca89b810e921efce95fb4d254a8c6c93180450b

# Upstream differs from base's default — re-point origin
RUN cd /workspace/ComfyUI && git remote set-url origin https://github.com/Comfy-Org/ComfyUI.git

RUN cd /workspace/ComfyUI && \
    git fetch --depth=1 origin ${BASE_COMMIT} && \
    git checkout -f FETCH_HEAD

WORKDIR /workspace/ComfyUI

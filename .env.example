# SWE-Together — environment template.
# Copy to .env at the repo root, then fill in the keys you need.
# Most evals only need a subset — the canonical launcher preflights what's
# required for the cohorts you're actually about to launch.

# ── Sandbox (required for any eval with --env-type e2b) ───────────────────
E2B_API_KEY=

# ── Step 1 agentic judge (subscription auth — flat cost) ─────────────────
# Extract from macOS keychain entry "Claude Code-credentials" (the JSON
# blob's .claudeAiOauth.accessToken field). On Linux, log in to claude-code
# CLI and read ~/.claude.json instead.
CLAUDE_CODE_OAUTH_TOKEN=
# Older alias kept for backward compat (writes to the same in-sandbox env):
ANTHROPIC_AUTH_TOKEN=
CLAUDE_ACCESS_TOKEN=

# ── User simulator (every eval) ──────────────────────────────────────────
GEMINI_API_KEY=

# ── Per-cohort provider keys ─────────────────────────────────────────────
# DS cohorts: direct API (cheap) OR fall back via OpenRouter if credit runs out
DEEPSEEK_API_KEY=
# Opus cohorts: always via OpenRouter
OPENROUTER_API_KEY=
# GPT cohorts: ChatGPT codex OAuth — log in via `codex` CLI to materialize
# ~/.codex/auth.json. OPENAI_API_KEY can be a placeholder when the codex
# OAuth path is active; LiteLLM only validates its presence.
OPENAI_API_KEY=sk-placeholder-ignored-by-oauth-proxy
# Optional Anthropic direct API key — leave blank to force OAuth/OR routing
ANTHROPIC_API_KEY=

# ── Extra providers (set only when running those cohort routes) ──────────
GOOGLE_API_KEY=
GLM_API_KEY=
MINIMAX_API_KEY=
ARK_API_KEY=
CHUTES_API_KEY=
FIREWORKS_API_KEY=
ZAI_API_KEY=

# ── GHCR auth for private task images (ghcr.io/togetherbench/*) ─────────
# Classic PAT with read:packages scope — gh CLI default token is insufficient.
GHCR_USER=
GHCR_TOKEN=

# ── Optional ─────────────────────────────────────────────────────────────
GITHUB_TOKEN=
REBUILD_TOKEN=
BUCKET_NAME=

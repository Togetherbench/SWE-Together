{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://togetherbench.dev/schemas/agent_session.schema.json",
  "title": "Agent Session",
  "description": "Unified per-turn JSONL schema for agent sessions in multi-user-turn-codebench. Covers ORACLE sessions (extracted from real human + agent sessions; used as the grading target for harbor tasks) and TRIAL sessions (a model's run against a harbor task). Each session is one JSONL file. Line 0 is the HEADER row (must set `_is_header: true`) and carries session-wide metadata. Lines 1..N are TURN rows, one per real user message + agent response. The header's `_grading_patch` is the AUTHORITATIVE diff for scoring; turn-row `cumulative_patch` fields are per-turn replay snapshots. They can legitimately differ (e.g., PR-diff oracle vs message-replay turn data). Human-edited audit metadata (review history, reliability flag) lives in a sibling `oracle_audit.json` to avoid bidirectional sync.",

  "$defs": {
    "git_sha": {
      "type": "string",
      "pattern": "^[0-9a-f]{7,40}$"
    },
    "iso_date": {
      "type": "string",
      "format": "date",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
    },
    "name_status_line": {
      "type": "string",
      "pattern": "^[AMDRCTU][0-9]*\\t[^\\n]+(\\t[^\\n]+)?$"
    },
    "numstat_line": {
      "type": "string",
      "pattern": "^([0-9]+|-)\\t([0-9]+|-)\\t[^\\n]+$"
    },
    "op": {
      "type": "object",
      "required": ["kind", "tool"],
      "properties": {
        "kind": {
          "type": "string",
          "enum": ["read", "edit", "write", "bash", "search", "test", "other"]
        },
        "tool":   { "type": "string" },
        "target": { "type": "string" },
        "detail": { "type": "string" }
      },
      "additionalProperties": true
    },

    "header_row": {
      "type": "object",
      "required": [
        "_is_header",
        "schema",
        "_kind",
        "_task_name",
        "_status"
      ],
      "properties": {

        "_is_header": { "type": "boolean", "const": true },

        "schema": {
          "type": "string",
          "const": "agent_session/2.0",
          "description": "Schema identifier. Bump on any breaking change."
        },

        "_kind": {
          "type": "string",
          "enum": ["oracle", "trial"],
          "description": "`oracle` = canonical session that grades a harbor task. `trial` = model's run against a harbor task."
        },

        "_task_name": {
          "type": "string",
          "description": "Harbor task directory name. Stable join key."
        },

        "_session_id": {
          "type": ["string", "null"],
          "description": "Upstream session UUID for oracle, trial UUID for trial. Null when no upstream session exists (PR-diff-only oracle)."
        },

        "_source": {
          "type": "string",
          "enum": [
            "agent-swarm", "amytis", "cc-backend", "cli", "comfyui",
            "dataclaw", "hand_curated", "hyperswitch", "pi-mono",
            "sd-scripts", "unknown"
          ],
          "description": "Upstream session corpus. Required for `_kind: oracle`."
        },

        "_status": {
          "type": "string",
          "enum": ["canonical", "no_canonical", "skip"],
          "description": "`canonical` = grading patch is present. `no_canonical` = stub; `_category` MUST be set, `_grading_patch` MUST be absent or empty. `skip` = replay/extraction skipped (e.g. clone failed); patch may or may not be present."
        },

        "_category": {
          "type": "string",
          "enum": [
            "stripped_export",
            "no_mutating_ops",
            "replay_no_diff",
            "hashline_unparseable",
            "unknown_no_canonical"
          ],
          "description": "Required iff `_status: no_canonical`. Why the patch could not be recovered."
        },

        "_reason": {
          "type": "string",
          "description": "Human-readable expansion of `_category` or skip reason."
        },

        "_base_commit": {
          "$ref": "#/$defs/git_sha",
          "description": "Commit BEFORE the fix; the Docker environment clones this."
        },

        "_repo_url": {
          "type": "string",
          "format": "uri"
        },

        "repo_id": {
          "type": "string",
          "pattern": "^[^/]+/[^/]+$"
        },

        "_grading_patch": {
          "type": ["string", "null"],
          "description": "AUTHORITATIVE unified diff for scoring. For oracle: extracted from PR / commit / message replay / hand-curated. For trial: omit (last turn's `cumulative_patch` is the grading target by definition)."
        },

        "_grading_patch_source": {
          "type": "string",
          "enum": [
            "gh_pr_diff",
            "upstream_commit_diff",
            "messages_replay",
            "codex_replay",
            "hand_curated",
            "verifier_aligned",
            "trial_final_turn",
            "none"
          ],
          "description": "How `_grading_patch` was produced. `trial_final_turn` is reserved for the trial side if you ever pre-compute it. `none` for stubs."
        },

        "_grading_patch_truncated": {
          "type": "boolean",
          "description": "Always written when `_grading_patch` is non-null. True iff hit by an upstream rollout truncation cap."
        },

        "_fidelity": {
          "type": "string",
          "enum": [
            "exact",
            "high",
            "directional",
            "lossy",
            "verifier_aligned",
            "no_canonical"
          ],
          "description": "Consumer-facing fidelity tier. Required for `_kind: oracle` when `_status: canonical`."
        },

        "_extraction": {
          "type": "object",
          "required": ["method", "fidelity"],
          "properties": {
            "method": {
              "type": "string",
              "enum": [
                "gh_pr_diff",
                "upstream_commit_diff",
                "messages_replay",
                "codex_replay",
                "hand_curated",
                "none"
              ]
            },
            "fidelity": {
              "type": "string",
              "enum": ["exact", "high", "directional", "lossy", "verifier_aligned", "none"]
            },
            "verified": { "type": "boolean" },
            "source":   { "type": "string" },
            "note":     { "type": "string" },
            "warnings": { "type": "array", "items": { "type": "string" } },
            "dated":    { "$ref": "#/$defs/iso_date" }
          },
          "additionalProperties": false
        },

        "files_changed": {
          "type": "string",
          "description": "`git diff --name-status` text (one line per file)."
        },
        "numstat": {
          "oneOf": [
            { "type": "array", "items": { "$ref": "#/$defs/numstat_line" } },
            { "type": "string" }
          ]
        },
        "files_changed_count": { "type": "integer", "minimum": 0 },
        "total_additions":     { "type": "integer", "minimum": 0 },
        "total_deletions":     { "type": "integer", "minimum": 0 },

        "commit_message": { "type": "string" },
        "commit_sha":     { "anyOf": [{ "type": "null" }, { "$ref": "#/$defs/git_sha" }] },
        "commits_in_checkpoint": { "type": "integer", "minimum": 0 },
        "is_agent_author":       { "type": "boolean" },

        "_n_mutating_ops": { "type": "integer", "minimum": 0 },

        "_replay_status": {
          "type": "string",
          "description": "`ok` if per-turn cumulative replay succeeded, else `skip:<reason>` (clone failed, no dockerfile, etc.)."
        },

        "_total_replay_warnings": { "type": "integer", "minimum": 0 },

        "_instruction_verbatim_enforced": { "type": "boolean" },
        "_instruction_pii_redacted":      { "type": "boolean" },

        "_canonical_source_path": {
          "type": "string",
          "description": "For promoted oracles: relative path back to the data-pipeline staging session (e.g. `data-pipeline/sessions/<sid>.jsonl`)."
        },

        "_audit_sidecar_path": {
          "type": "string",
          "description": "Relative path to the human-editable audit sidecar (e.g. `oracle_audit.json`). When present, that file holds `_review`, `_review_history`, `_reliability`."
        },

        "_sync_note": { "type": "string" },

        "_model":            { "type": "string", "description": "Trial only. Resolved model id (e.g. `claude-opus-4-6`, `glm-5.1`)." },
        "_cohort":           { "type": "string", "description": "Trial only. Cohort directory name." },
        "_trial_id":         { "type": "string", "description": "Trial only. Trial UUID." },
        "_harness_version":  { "type": "string", "description": "Trial only. Pinned Claude Code CLI version (e.g. `2.1.108`)." },
        "_final_reward":     { "type": "number", "minimum": 0.0, "maximum": 1.0, "description": "Trial only. Verifier reward at end of trial (cached from `verifier/reward.txt` for analytics)." }
      },
      "additionalProperties": false,

      "allOf": [
        {
          "if": { "properties": { "_kind": { "const": "oracle" } } },
          "then": { "required": ["_source"] }
        },
        {
          "if": { "properties": { "_kind": { "const": "trial" } } },
          "then": { "required": ["_model", "_cohort", "_trial_id"] }
        },
        {
          "if": {
            "properties": {
              "_kind":   { "const": "oracle" },
              "_status": { "const": "canonical" }
            },
            "required": ["_kind", "_status"]
          },
          "then": {
            "required": [
              "_grading_patch",
              "_grading_patch_source",
              "_grading_patch_truncated",
              "_fidelity",
              "_base_commit",
              "_repo_url",
              "repo_id"
            ],
            "properties": {
              "_grading_patch": {
                "type": "string",
                "minLength": 1,
                "description": "Canonical oracle MUST carry a non-empty diff. Empty string is not a valid grading target; use `_status: no_canonical` for tasks without a patch."
              }
            }
          }
        },
        {
          "if": { "properties": { "_status": { "const": "no_canonical" } } },
          "then": {
            "required": ["_category", "_reason"],
            "not": { "required": ["_grading_patch"] }
          }
        }
      ]
    },

    "turn_row": {
      "type": "object",
      "required": ["turn"],
      "properties": {

        "turn": { "type": "integer", "minimum": 0 },

        "user_message":       { "type": "string" },
        "user_message_chars": { "type": "integer", "minimum": 0 },
        "msg_range": {
          "type": "array",
          "items": { "type": "integer", "minimum": 0 },
          "minItems": 2,
          "maxItems": 2
        },

        "agent_text":           { "type": "string" },
        "agent_thinking_chars": { "type": "integer", "minimum": 0 },

        "ops": {
          "type": "array",
          "items": { "$ref": "#/$defs/op" }
        },

        "files_read":      { "type": "array", "items": { "type": "string" } },
        "files_edited":    { "type": "array", "items": { "type": "string" } },
        "files_written":   { "type": "array", "items": { "type": "string" } },
        "bash_commands":   { "type": "array", "items": { "type": "string" } },
        "test_invocations":{ "type": "array", "items": { "type": "string" } },

        "n_tool_calls":      { "type": "integer", "minimum": 0 },
        "n_mutating_ops":    { "type": "integer", "minimum": 0 },
        "completion_signaled": { "type": "boolean" },

        "cumulative_patch":                { "type": ["string", "null"] },
        "cumulative_patch_truncated":      { "type": "boolean" },
        "cumulative_files_changed_count":  { "type": "integer", "minimum": 0 },
        "cumulative_additions":            { "type": "integer", "minimum": 0 },
        "cumulative_deletions":            { "type": "integer", "minimum": 0 },
        "replay_warnings_this_turn":       { "type": "array", "items": { "type": "string" } },

        "verifier_reward":            { "type": "number", "minimum": 0.0, "maximum": 1.0 },
        "verifier_gates":             { "type": "object" }
      },
      "additionalProperties": false
    }
  },

  "oneOf": [
    { "$ref": "#/$defs/header_row" },
    { "$ref": "#/$defs/turn_row"   }
  ]
}

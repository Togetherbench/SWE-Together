+class LuminaEmbedND(nn.Module):
+    def __init__(self, dim: int, theta: int, axes_dim: list, axes_lens: list = None):
+        super().__init__()
+        self.dim = dim
+        self.theta = theta
+        self.axes_dim = axes_dim
+        self.axes_lens = axes_lens
+        if axes_lens is not None:
+            for i, (d, l) in enumerate(zip(axes_dim, axes_lens)):
+                pos = torch.arange(l).unsqueeze(0)
+                freqs = rope(pos, d, theta)
+                freqs = freqs.squeeze(0)
+                self.register_buffer(f"freqs_{i}", freqs.view(l, -1))
+
+    def forward(self, ids: torch.Tensor) -> torch.Tensor:
+        if self.axes_lens is None:
+            n_axes = ids.shape[-1]
+            emb = torch.cat(
+                [rope(ids[..., i], self.axes_dim[i], self.theta) for i in range(n_axes)],
+                dim=-3,
+            )
+            return emb.unsqueeze(1)
+
+        n_axes = ids.shape[-1]
+        emb_list = []
+        for i in range(n_axes):
+            freqs = getattr(self, f"freqs_{i}")
+            idx = ids[..., i].long()
+            part = F.embedding(idx, freqs)
+            part = part.view(*idx.shape, self.axes_dim[i], 2, 2)
+            emb_list.append(part)
+        
+        emb = torch.cat(emb_list, dim=-3)
+        return emb.unsqueeze(1)
+

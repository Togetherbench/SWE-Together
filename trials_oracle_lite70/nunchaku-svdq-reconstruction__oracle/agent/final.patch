+    packed_qweight = pack_svdq_qweight(orig_qweight)
+    unpacked_qweight = unpack_svdq_qweight(packed_qweight, N, K)
+    if torch.all(orig_qweight == unpacked_qweight.int()):
+        print("QWeight PASS")
+    else:
+        print("QWeight FAIL")
+        print(orig_qweight.flatten()[:10])
+        print(unpacked_qweight.flatten()[:10])
+        
+    print("Testing Scale...")
+    orig_scale = torch.randn(N, K // 64)
+    packed_scale = pack_svdq_scale(orig_scale)
+    unpacked_scale = unpack_svdq_scale(packed_scale, N, K)
+    if torch.allclose(orig_scale, unpacked_scale):
+        print("Scale PASS")
+    else:
+        print("Scale FAIL")
+        
+    print("Testing LowRank (Up)...")
+    orig_up = torch.randn(N, 128)
+    packed_up = pack_svdq_lowrank(orig_up, down=False)
+    unpacked_up = unpack_svdq_lowrank(packed_up, down=False)
+    if torch.allclose(orig_up, unpacked_up):
+        print("LowRank Up PASS")
+    else:
+        print("LowRank Up FAIL")
+        
+    print("Testing LowRank (Down)...")
+    orig_down = torch.randn(3072, 128)
+    packed_down = pack_svdq_lowrank(orig_down, down=True)
+    unpacked_down = unpack_svdq_lowrank(packed_down, down=True)
+    if torch.allclose(orig_down, unpacked_down):
+        print("LowRank Down PASS")
+    else:
+        print("LowRank Down FAIL")
+
+if __name__ == "__main__":
+    main()

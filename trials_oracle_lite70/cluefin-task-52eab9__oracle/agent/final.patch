diff --git a/.github/ISSUE_TEMPLATE/bug-report.yml b/.github/ISSUE_TEMPLATE/bug-report.yml
new file mode 100644
index 0000000..90efbbf
--- /dev/null
+++ b/.github/ISSUE_TEMPLATE/bug-report.yml
@@ -0,0 +1,95 @@
+name: 버그 리포트
+description: 버그를 발견한 경우 사용해주세요.
+title: "[BUG] "
+labels: ["bug"]
+body:
+  - type: checkboxes
+    id: checklist
+    attributes:
+      label: 사전 체크리스트
+      options:
+        - label: 기존 이슈에서 동일한 버그가 보고된 적 없는지 확인했습니다.
+          required: true
+        - label: 최신 버전에서도 동일한 문제가 발생하는지 확인했습니다.
+          required: true
+
+  - type: input
+    id: version
+    attributes:
+      label: 버전
+      description: "`uv pip show cluefin-openapi` 등으로 확인한 패키지 버전을 입력해주세요."
+      placeholder: "예: cluefin-openapi 0.3.7"
+    validations:
+      required: true
+
+  - type: dropdown
+    id: package
+    attributes:
+      label: 영향 패키지
+      description: 버그가 발생한 패키지를 선택해주세요.
+      multiple: true
+      options:
+        - cluefin-openapi
+        - cluefin-ta
+        - cluefin-cli
+        - cluefin-desk
+        - cluefin-xbrl
+    validations:
+      required: true
+
+  - type: textarea
+    id: description
+    attributes:
+      label: 버그 설명
+      description: 어떤 버그인지 간결하게 설명해주세요.
+    validations:
+      required: true
+
+  - type: textarea
+    id: reproduction
+    attributes:
+      label: 재현 절차
+      description: 버그를 재현할 수 있는 단계를 작성해주세요.
+      placeholder: |
+        1. `uv run python -c "from cluefin_openapi import ..."`
+        2. 특정 함수 호출
+        3. 에러 발생
+    validations:
+      required: true
+
+  - type: textarea
+    id: expected
+    attributes:
+      label: 기대 동작
+      description: 정상적으로 동작했을 때 기대하는 결과를 설명해주세요.
+    validations:
+      required: true
+
+  - type: textarea
+    id: actual
+    attributes:
+      label: 실제 동작
+      description: 실제로 발생한 결과를 설명해주세요.
+    validations:
+      required: true
+
+  - type: textarea
+    id: environment
+    attributes:
+      label: 환경 정보
+      description: OS, Python, uv 버전 등 환경 정보를 입력해주세요.
+      placeholder: |
+        - OS: macOS 15.x / Ubuntu 24.04
+        - Python: 3.10.x
+        - uv: 0.x.x
+    validations:
+      required: false
+
+  - type: textarea
+    id: logs
+    attributes:
+      label: 에러 로그
+      description: 관련 에러 로그가 있다면 붙여넣어 주세요.
+      render: bash
+    validations:
+      required: false
diff --git a/.github/ISSUE_TEMPLATE/config.yml b/.github/ISSUE_TEMPLATE/config.yml
new file mode 100644
index 0000000..3ba13e0
--- /dev/null
+++ b/.github/ISSUE_TEMPLATE/config.yml
@@ -0,0 +1 @@
+blank_issues_enabled: false
diff --git a/.github/ISSUE_TEMPLATE/feature-request.yml b/.github/ISSUE_TEMPLATE/feature-request.yml
new file mode 100644
index 0000000..ec4b768
--- /dev/null
+++ b/.github/ISSUE_TEMPLATE/feature-request.yml
@@ -0,0 +1,67 @@
+name: 기능 요청
+description: 새로운 기능이나 개선 사항을 제안해주세요.
+title: "[FEAT] "
+labels: ["enhancement"]
+body:
+  - type: checkboxes
+    id: checklist
+    attributes:
+      label: 사전 체크리스트
+      options:
+        - label: 기존 이슈에서 동일한 기능이 요청된 적 없는지 확인했습니다.
+          required: true
+
+  - type: dropdown
+    id: package
+    attributes:
+      label: 영향 패키지
+      description: 기능이 추가될 패키지를 선택해주세요.
+      multiple: true
+      options:
+        - cluefin-openapi
+        - cluefin-ta
+        - cluefin-cli
+        - cluefin-desk
+        - cluefin-xbrl
+    validations:
+      required: true
+
+  - type: textarea
+    id: description
+    attributes:
+      label: 설명
+      description: 제안하는 기능을 설명해주세요.
+    validations:
+      required: true
+
+  - type: textarea
+    id: motivation
+    attributes:
+      label: 동기
+      description: 이 기능이 왜 필요한지 설명해주세요.
+    validations:
+      required: true
+
+  - type: textarea
+    id: solution
+    attributes:
+      label: 제안하는 해결 방법
+      description: 기능을 어떻게 구현하면 좋을지 제안해주세요.
+    validations:
+      required: true
+
+  - type: textarea
+    id: alternatives
+    attributes:
+      label: 대안
+      description: 고려한 대안이 있다면 설명해주세요.
+    validations:
+      required: false
+
+  - type: textarea
+    id: additional
+    attributes:
+      label: 추가 정보
+      description: 참고 자료, 스크린샷 등 추가 정보가 있다면 공유해주세요.
+    validations:
+      required: false
